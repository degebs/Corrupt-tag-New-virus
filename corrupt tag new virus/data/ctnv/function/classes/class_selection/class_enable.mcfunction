#medic
execute as @a[team=party_lead] if items entity @s player.cursor red_stained_glass_pane[custom_name=[{"text":"Medic","italic":false,"color":"red"}],lore=[[{"text":"--- item ---","italic":false,"color":"dark_aqua"}],[{"text":"- healing rose (drop to heal)","italic":false,"color":"white"}],[{"text":"- healing rose can heal teamates","italic":false,"color":"yellow"}],[{"text":"--- weapon ---","italic":false,"color":"dark_aqua"}],[{"text":"- medical knockback shovel","italic":false,"color":"white"}],[{"text":"--- movement ---","italic":false,"color":"dark_aqua"}],[{"text":"- jump boost when using the healing rose","italic":false,"color":"white"}],[{"text":"- only works in endgame","italic":false,"color":"red"}]]] run scoreboard players set @s class_enable_click_check 1
execute as @a[team=party_lead] if score @s class_enable_click_check matches 1 unless items entity @s inventory.0 red_stained_glass_pane run tellraw @a [{"text":"[✔] ","color":"green","bold":true},{"text":"Medic","color":"red","bold":true},{"text":" will be enabled!","color":"gray"}]
execute as @a[team=party_lead] if score @s class_enable_click_check matches 1 unless items entity @s inventory.0 red_stained_glass_pane run playsound block.respawn_anchor.charge block @a ~ ~ ~ 1 1 1
execute as @a[team=party_lead] if score @s class_enable_click_check matches 1 unless items entity @s inventory.0 red_stained_glass_pane run scoreboard players set enable select_medic 1
