# if the party leaders score is 1 in select_[CLASSNAME] then we enable it or disable it
kill @e[type=item,nbt={Item:{id:"minecraft:red_stained_glass_pane"}}]
scoreboard objectives add class_enable_check minecraft.dropped:red_stained_glass_pane
scoreboard objectives add class_enable_click_check dummy

# THE LOGIC TO THIS
# 1 we disable the class by placing a red stained glass pane in the players inventory and setting the enable score to 0
# 2 if the party leader clicks on the red stained glass pane we need to check witch glass paine is missing from the inventory
# 3 that missing glass paine will tell us witch class to enable and we set the enable score to 1

