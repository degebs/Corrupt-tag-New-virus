# for this one we just do nothing.
# for this i guess we can fill the players inventory slots with colorfull stained glass panes
# randomly assign each player a number 1-16 (one per glass pane color)
scoreboard objectives add rand_glass dummy
execute if score tick time matches 6 run scoreboard players add @a rand_glass 1
execute if score tick time matches 12 run scoreboard players add @a rand_glass 1
execute if score tick time matches 18 run scoreboard players add @a rand_glass 1


execute if score @r rand_glass matches 17.. run scoreboard players set @a rand_glass 1
