# do some cleanup before we give the medic the item
# turns out this code casues the item to pulse like a heatbeat, which is a really nice effect, so I am keeping it in
execute if score tick time matches 5 run clear @s minecraft:heart_of_the_sea
execute if score tick time matches 10 if score @s medic_health_detector matches 1 run clear @s minecraft:heart_of_the_sea
execute if score tick time matches 15 if score @s medic_health_detector matches 1..2 run clear @s minecraft:heart_of_the_sea
execute if score tick time matches 19 if score @s medic_health_detector matches 1 run clear @s minecraft:heart_of_the_sea

# fastest heartbeat on 1 health
# faster heartbeat on 2 health
kill @e[type=item,nbt={Item:{id:"minecraft:heart_of_the_sea"}}]
kill @e[type=item,nbt={Item:{id:"minecraft:painting"}}]

# visual indicator of the nearest runners health
execute if score @s medic_health_detector matches 1 run item replace entity @s hotbar.7 with minecraft:heart_of_the_sea[custom_name=[{"text":"Nearest runner has 1 health","color":"white"}],enchantment_glint_override=true,rarity=rare] 1
